# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── IDEs ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Large data files (don't commit raw datasets or videos) ───────────────
*.zip
data/
VisDrone2019-DET-val/
data/visdrone_yolo/

# ── Output videos (too large for git) ────────────────────────────────────
out/
out_finetuned/

# ── Model weights (large binaries — track via git-lfs or releases) ────────
*.pt
*.pth
*.onnx

# ── Training run artifacts ────────────────────────────────────────────────
runs/
# Keep results CSVs if you want:
!runs/**/results.csv
!runs/**/args.yaml

# ── Ultralytics cache / datasets auto-download ────────────────────────────
datasets/
ultralytics/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
*.log.*
